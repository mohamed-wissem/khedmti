# ---------------------------------------------------------------------------
# BLACKFORGE API — environment template. Copy to `.env` and fill in.
# Never commit a real `.env`.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# CORS — comma-separated allowlist of origins (use * only in local dev)
CORS_ORIGIN=http://localhost:3000

# Database (Neon). The API owns the `bfapi` schema; never touch public/blackforge.
# Pooled connection for the app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&schema=bfapi"
# Direct (unpooled) connection for migrations:
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&schema=bfapi"

# Redis
REDIS_URL=redis://localhost:6379

# Auth secrets (REQUIRED) — generate with: openssl rand -base64 48
JWT_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long

# Stripe (used from Sprint 4 — optional until then)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary (used from Sprint 2 — optional until then)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
